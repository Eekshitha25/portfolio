# Optional: add a real Anthropic API key to power the chat widget with live Claude
# responses (grounded in lib/profileData.ts) instead of the built-in rule-based
# fallback. Without this key, the chatbot still works perfectly using local
# keyword-matched answers — no cost, no setup required.
#
# Get a key at https://console.anthropic.com → API Keys
# Then add it as an environment variable named ANTHROPIC_API_KEY in:
#   - Local dev: create a file named .env.local with the line below
#   - Vercel: Project Settings → Environment Variables

ANTHROPIC_API_KEY=
